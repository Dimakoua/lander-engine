{
  "name": "lander-engine",
  "version": "0.1.0",
  "description": "Configuration-driven JAMstack landing page meta-framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "lander": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.mjs",
      "require": "./dist/cli/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.mjs",
      "require": "./dist/resolver/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "astro": "^4.5.0",
    "cac": "^6.7.14",
    "clsx": "^2.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "nanostores": "^0.10.0",
    "tailwind-merge": "^2.2.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.24",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
