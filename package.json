{
  "name": "lander-engine",
  "version": "0.1.0",
  "description": "Configuration-driven JAMstack landing page meta-framework",
  "license": "MIT",
  "author": "Lander Engine Contributors",
  "homepage": "https://github.com/yourusername/lander-engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/lander-engine.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/lander-engine/issues"
  },
  "keywords": [
    "astro",
    "landing-pages",
    "jamstack",
    "a-b-testing",
    "ab-testing",
    "configuration-driven",
    "meta-framework",
    "zero-js",
    "static-generation",
    "view-transitions"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lander": "./dist/cli/index.cjs"
  },
  "files": [
    "dist/",
    "templates/",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js",
      "require": "./dist/cli/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./resolver": {
      "types": "./dist/resolver/index.d.ts",
      "import": "./dist/resolver/index.js",
      "require": "./dist/resolver/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "astro": "^5.18.1",
    "cac": "^6.7.14",
    "clsx": "^2.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "nanostores": "^0.10.0",
    "tailwind-merge": "^2.2.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix",
    "**/*.{ts,tsx,md,json,js}": "prettier --write"
  }
}
