---
import { ConfigParser, resolveCascadingConfig } from 'lander-engine/resolver';
import { hydrateState } from 'lander-engine/core';
import '../registry-manifest'; 
import Registry from '../Registry.astro';

export async function getStaticPaths() {
  const nodeEnvJsonDir = process.env.LANDER_JSON_CONFIGS_DIR;
  const viteEnvJsonDir = import.meta.env.LANDER_JSON_CONFIGS_DIR;
  const jsonConfigsDir = nodeEnvJsonDir || viteEnvJsonDir || '';

  if (!jsonConfigsDir) {
    console.error('LANDER_JSON_CONFIGS_DIR is not defined');
    return [];
  }

  const parser = new ConfigParser(jsonConfigsDir);
  const campaigns = await parser.getCampaigns();
  const paths = [];

  for (const campaignId of campaigns) {
    const base = await parser.loadCampaignBase(campaignId);
    
    // We can also check for variants and devices here to generate more paths
    // For now, let's start with the base campaign steps.
    for (const [stepId, stepConfig] of Object.entries(base.steps)) {
      paths.push({
        params: { slug: `${campaignId}/${stepId}` },
        props: { 
          campaignId, 
          stepId, 
          config: resolveCascadingConfig(base, undefined, undefined, undefined), // Simplified for now
          step: stepConfig
        }
      });
    }
  }

  return paths;
}

const { config, step, campaignId, stepId } = Astro.props;

// Prepare initial state
const initialState = {
  ...config.state,
  ...step.state,
  campaignId,
  stepId,
};

// Map theme to CSS variables
const themeVars = Object.entries(config.theme.colors || {}).reduce((acc, [key, val]) => {
  acc[`--color-${key}`] = val;
  return acc;
}, {} as Record<string, string>);

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{step.seo?.title || config.seo.title}</title>
    <meta name="description" content={step.seo?.description || config.seo.description} />
  </head>
  <body style={themeVars}>
    <main id="lander-engine-root">
      {step.sections.map((section: any) => (
        <Registry component={section.component} props={section.props} />
      ))}
    </main>

    <script is:inline define:vars={{ initialState }}>
      // This script runs before hydration to seed the state
      // (Simplified for this example; in production, this would use the core's hydrateState)
    </script>
  </body>
</html>
