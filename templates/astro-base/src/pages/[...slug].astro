---
import { ConfigParser, resolveCascadingConfig } from 'lander-engine/resolver';
import { hydrateState } from 'lander-engine/core';
import '../registry-manifest'; 
import Registry from '../Registry.astro';
import ModalsContainer from '../ModalsContainer.astro';

export async function getStaticPaths() {
  const nodeEnvJsonDir = process.env.LANDER_JSON_CONFIGS_DIR;
  const viteEnvJsonDir = import.meta.env.LANDER_JSON_CONFIGS_DIR;
  const jsonConfigsDir = nodeEnvJsonDir || viteEnvJsonDir || '';

  if (!jsonConfigsDir) {
    console.error('LANDER_JSON_CONFIGS_DIR is not defined');
    return [];
  }

  const parser = new ConfigParser(jsonConfigsDir);
  const campaigns = await parser.getCampaigns();
  const paths = [];

  for (const campaignId of campaigns) {
    const base = await parser.loadCampaignBase(campaignId);
    
    // Load mobile overrides if they exist
    let mobileOverrides = {};
    try {
      mobileOverrides = await parser.loadOverrides(campaignId, 'mobile');
    } catch (e) {
      // Mobile overrides are optional
    }
    
    // Filter out popup steps - only generate routes for normal steps
    // Popups are rendered as modals within normal steps
    // Campaign root → redirect to initialStep
    const initialStepId = base.flow.initialStep;
    const initialStepConfig = base.steps[initialStepId];
    if (initialStepConfig) {
      paths.push({
        params: { slug: campaignId },
        props: {
          campaignId,
          stepId: initialStepId,
          isMobile: false,
          isRedirect: true,
          redirectTo: `/${campaignId}/${initialStepId}`,
          base,
          mobileOverrides,
          config: resolveCascadingConfig(base, undefined, undefined, undefined),
          step: initialStepConfig,
          flow: base.flow,
          allSteps: base.steps,
          modalConfigs: base.flow.modals || {},
          layout: base.layout || {},
        },
      });
    }

    for (const [stepId, stepConfig] of Object.entries(base.steps)) {
      const stepType = base.flow.steps[stepId]?.type;
      
      // Only create routes for normal steps, skip popups
      if (stepType !== 'popup') {
        // Desktop version
        paths.push({
          params: { slug: `${campaignId}/${stepId}` },
          props: { 
            campaignId, 
            stepId, 
            isMobile: false,
            base,
            mobileOverrides,
            config: resolveCascadingConfig(base, undefined, undefined, undefined),
            step: stepConfig,
            flow: base.flow,
            allSteps: base.steps,
            modalConfigs: base.flow.modals || {},
            layout: base.layout || {}
          }
        });
        
        // Mobile version (only if mobile overrides exist)
        if (Object.keys(mobileOverrides).length > 0) {
          paths.push({
            params: { slug: `${campaignId}/${stepId}.mobile` },
            props: { 
              campaignId, 
              stepId, 
              isMobile: true,
              base,
              mobileOverrides,
              config: resolveCascadingConfig(base, mobileOverrides as any, undefined, undefined),
              step: mobileOverrides.steps?.[stepId] ? { ...stepConfig, ...mobileOverrides.steps[stepId] } : stepConfig,
              flow: mobileOverrides.flow ? { ...base.flow, ...mobileOverrides.flow } : base.flow,
              allSteps: base.steps,
              modalConfigs: mobileOverrides.flow?.modals ? { ...base.flow.modals, ...mobileOverrides.flow.modals } : (base.flow.modals || {}),
              layout: mobileOverrides.layout ? { ...base.layout, ...mobileOverrides.layout } : (base.layout || {})
            }
          });
        }
      }
    }
  }

  return paths;
}

const { isMobile, config, step, campaignId, stepId, flow, allSteps, modalConfigs, layout, isRedirect, redirectTo } = Astro.props;

// Redirect /{campaignId} → /{campaignId}/{initialStep}
if (isRedirect && redirectTo) {
  return Astro.redirect(redirectTo, 302);
}

// Prepare initial state
const initialState = {
  ...config.state,
  ...step.state,
  isMobile, // Include device type in state for reactive components
  campaignId,
  stepId,
};

// Collect available popups for this step (popups that can be triggered from this step)
const availablePopups: Record<string, any> = {};
for (const [popupId, popupStepConfig] of Object.entries(allSteps)) {
  if (flow.steps[popupId]?.type === 'popup') {
    availablePopups[popupId] = popupStepConfig;
  }
}

// Map theme to CSS variables
const themeVars = Object.entries(config.theme.colors || {}).reduce((acc, [key, val]) => {
  acc[`--color-${key}`] = val;
  return acc;
}, {} as Record<string, string>);

// Favicon: use campaign-defined value or fall back to /favicon.svg
const faviconHref = config.theme.favicon || '/favicon.svg';
const faviconExt = faviconHref.split('?')[0].split('.').pop()?.toLowerCase() ?? '';
const faviconType: Record<string, string> = {
  svg:  'image/svg+xml',
  ico:  'image/x-icon',
  png:  'image/png',
  jpg:  'image/jpeg',
  jpeg: 'image/jpeg',
  webp: 'image/webp',
};
const faviconMime = faviconType[faviconExt] ?? 'image/x-icon';

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type={faviconMime} href={faviconHref} />
    <meta name="viewport" content="width=device-width" />
    <title>{step.seo?.title || config.seo.title}</title>
    <meta name="description" content={step.seo?.description || config.seo.description} />
  </head>
  <body style={themeVars}>
    {layout?.header && (
      <header id="lander-header">
        <Registry component={layout.header.component} props={layout.header.props} />
      </header>
    )}
    
    <main id="lander-engine-root">
      {step.sections.map((section: any) => (
        <Registry component={section.component} props={section.props} />
      ))}
    </main>

    {layout?.footer && (
      <footer id="lander-footer">
        <Registry component={layout.footer.component} props={layout.footer.props} />
      </footer>
    )}

    <ModalsContainer popups={availablePopups} modalConfigs={modalConfigs} />

    <script is:inline>
      // Client-side device detection and redirect
      function isMobileDevice() {
        const userAgent = navigator.userAgent || navigator.vendor || window.opera;
        const mobilePattern = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i;
        return mobilePattern.test(userAgent);
      }

      function shouldRedirect() {
        const currentPath = window.location.pathname;
        const isMobileDevice_ = isMobileDevice();
        const isOnMobilePage = currentPath.includes('.mobile');

        // Don't redirect in dev mode with query string
        if (window.location.search.includes('no-redirect')) {
          return false;
        }

        // If on desktop but should be on mobile
        if (!isOnMobilePage && isMobileDevice_) {
          return true;
        }

        // If on mobile but should be on desktop
        if (isOnMobilePage && !isMobileDevice_) {
          return true;
        }

        return false;
      }

      if (shouldRedirect()) {
        const currentPath = window.location.pathname;
        let redirectPath = currentPath;

        if (currentPath.includes('.mobile')) {
          // Remove .mobile from the path
          redirectPath = currentPath.replace('.mobile', '');
        } else {
          // Add .mobile to the path
          redirectPath = currentPath.replace(/\/$/, '') + '.mobile';
        }

        window.location.href = redirectPath + window.location.search;
      }
    </script>

    <script is:inline define:vars={{ initialState }}>
      // This script runs before hydration to seed the state
      // (Simplified for this example; in production, this would use the core's hydrateState)
      
      // Handle backdrop click to close modals
      document.addEventListener('click', (e) => {
        const modal = e.target.closest('.lander-modal');
        if (modal && e.target === modal) {
          const closeOnBackdrop = modal.dataset.closeOnBackdrop === 'true';
          if (closeOnBackdrop) {
            modal.classList.add('modal-hidden');
          }
        }
      });
    </script>
  </body>
</html>
