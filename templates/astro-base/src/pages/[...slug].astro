---
import { ConfigParser, resolveCascadingConfig } from 'lander-engine/resolver';
import { hydrateState } from 'lander-engine/core';
import { ViewTransitions } from 'astro:transitions';
import '../registry-manifest'; 
import Registry from '../Registry.astro';
import ModalsContainer from '../ModalsContainer.astro';

export async function getStaticPaths() {
  const nodeEnvJsonDir = process.env.LANDER_JSON_CONFIGS_DIR;
  const viteEnvJsonDir = import.meta.env.LANDER_JSON_CONFIGS_DIR;
  const jsonConfigsDir = nodeEnvJsonDir || viteEnvJsonDir || '';

  if (!jsonConfigsDir) {
    console.error('LANDER_JSON_CONFIGS_DIR is not defined');
    return [];
  }

  const parser = new ConfigParser(jsonConfigsDir);
  const campaigns = await parser.getCampaigns();
  const paths = [];

  for (const campaignId of campaigns) {
    const base = await parser.loadCampaignBase(campaignId);

    // Load base mobile (device) overrides
    let mobileOverrides: any = {};
    try {
      mobileOverrides = await parser.loadOverrides(campaignId, 'mobile');
    } catch (e) {
      // Mobile overrides are optional
    }
    const hasMobile = Object.keys(mobileOverrides).length > 0;

    // Discover A/B variant subdirectories and load their overrides
    const variants = await parser.getVariants(campaignId);
    const variantOverridesMap: Record<string, any> = {};
    const variantMobileOverridesMap: Record<string, any> = {};

    for (const variant of variants) {
      try {
        variantOverridesMap[variant] = await parser.loadOverrides(campaignId, variant);
      } catch (e) {
        variantOverridesMap[variant] = {};
      }
      try {
        variantMobileOverridesMap[variant] = await parser.loadOverrides(campaignId, `${variant}/mobile`);
      } catch (e) {
        variantMobileOverridesMap[variant] = {};
      }
    }

    /**
     * Build the resolved props for a single page path.
     * Priority: Base < Device (mobile) < Variant < Variant+Device
     */
    function buildProps(
      stepId: string,
      isMobile: boolean,
      variant: string | null,
      hasMobileRoute: boolean,
    ) {
      const deviceOverride   = isMobile ? mobileOverrides : undefined;
      const variantOverride  = variant ? variantOverridesMap[variant] : undefined;
      const variantMobileOv  = variant && isMobile ? variantMobileOverridesMap[variant] : undefined;

      const resolvedConfig = resolveCascadingConfig(
        base,
        deviceOverride,
        variantOverride,
        variantMobileOv,
      );

      return {
        campaignId,
        stepId,
        isMobile,
        variant,
        variants,
        hasMobileRoute,
        config: resolvedConfig,
        step: resolvedConfig.steps[stepId] ?? base.steps[stepId],
        flow: resolvedConfig.flow,
        allSteps: resolvedConfig.steps,
        modalConfigs: resolvedConfig.flow?.modals ?? {},
        layout: resolvedConfig.layout ?? {},
      };
    }

    // Campaign root → server-redirect to initial step (variant assignment happens client-side)
    const initialStepId = base.flow.initialStep;
    if (base.steps[initialStepId]) {
      paths.push({
        params: { slug: campaignId },
        props: {
          isRedirect: true,
          redirectTo: `/${campaignId}/${initialStepId}`,
        },
      });
    }

    for (const [stepId] of Object.entries(base.steps)) {
      const stepType = base.flow.steps[stepId]?.type;
      // Popup steps render as modals inside normal pages — no dedicated routes
      if (stepType === 'popup') continue;

      // 1. Base desktop
      paths.push({
        params: { slug: `${campaignId}/${stepId}` },
        props: buildProps(stepId, false, null, hasMobile),
      });

      // 2. Base mobile (only if a mobile/ directory exists)
      if (hasMobile) {
        paths.push({
          params: { slug: `${campaignId}/${stepId}.mobile` },
          props: buildProps(stepId, true, null, hasMobile),
        });
      }

      // 3. Variant routes
      for (const variant of variants) {
        const vmo = variantMobileOverridesMap[variant];
        // Generate a variant mobile route when the campaign has base mobile overrides
        // OR when this variant has its own mobile overrides.
        const hasVariantMobile = hasMobile || Object.keys(vmo).length > 0;

        // Variant desktop
        paths.push({
          params: { slug: `${campaignId}/${stepId}.${variant}` },
          props: buildProps(stepId, false, variant, hasVariantMobile),
        });

        // Variant mobile
        if (hasVariantMobile) {
          paths.push({
            params: { slug: `${campaignId}/${stepId}.${variant}.mobile` },
            props: buildProps(stepId, true, variant, hasVariantMobile),
          });
        }
      }
    }
  }

  return paths;
}

const {
  isRedirect,
  redirectTo,
  isMobile,
  variant,
  variants,
  hasMobileRoute,
  config,
  step,
  campaignId,
  stepId,
  flow,
  allSteps,
  modalConfigs,
  layout,
} = Astro.props;

// Campaign root redirect: /{campaignId} → /{campaignId}/{initialStep}
if (isRedirect && redirectTo) {
  return Astro.redirect(redirectTo, 302);
}

const initialState = {
  ...config.state,
  ...step.state,
  isMobile,
  variant,
  campaignId,
  stepId,
};

// Collect popup steps for ModalsContainer
const availablePopups: Record<string, any> = {};
for (const [popupId, popupStepConfig] of Object.entries(allSteps)) {
  if (flow.steps[popupId]?.type === 'popup') {
    availablePopups[popupId] = popupStepConfig;
  }
}

// Map theme colors to CSS custom properties
const themeVars = Object.entries(config.theme.colors || {}).reduce((acc, [key, val]) => {
  acc[`--color-${key}`] = val;
  return acc;
}, {} as Record<string, string>);

const faviconHref = config.theme.favicon || '/favicon.svg';
const faviconExt = faviconHref.split('?')[0].split('.').pop()?.toLowerCase() ?? '';
const faviconType: Record<string, string> = {
  svg:  'image/svg+xml',
  ico:  'image/x-icon',
  png:  'image/png',
  jpg:  'image/jpeg',
  jpeg: 'image/jpeg',
  webp: 'image/webp',
};
const faviconMime = faviconType[faviconExt] ?? 'image/x-icon';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type={faviconMime} href={faviconHref} />
    <meta name="viewport" content="width=device-width" />
    <title>{step.seo?.title || config.seo.title}</title>
    <meta name="description" content={step.seo?.description || config.seo.description} />
    <!-- Hide until redirect check completes to prevent flash of wrong URL -->
    <style>body { visibility: hidden; }</style>
    <ViewTransitions />
  </head>
  <body style={themeVars}>
    {layout?.header && (
      <header id="lander-header">
        <Registry component={layout.header.component} props={layout.header.props} />
      </header>
    )}

    <main id="lander-engine-root">
      {step.sections.map((section: any) => (
        <Registry component={section.component} props={section.props} />
      ))}
    </main>

    {layout?.footer && (
      <footer id="lander-footer">
        <Registry component={layout.footer.component} props={layout.footer.props} />
      </footer>
    )}

    <ModalsContainer popups={availablePopups} modalConfigs={modalConfigs} />

    <script>
      import '../registry-manifest';
    </script>

    <!--
      SPA navigation helpers.

      Two-part strategy:
        1. is:inline script (below) registers campaign config and immediately
           shows the body when the URL is already correct.  No hard redirects.
        2. This module script owns ALL redirects (via navigate()) and link
           rewriting so there is never a location.replace() hard reload.
    -->
    <script>
      import { navigate } from 'astro:transitions/client';

      // Expose helpers for the action dispatcher (core package has no direct
      // access to Astro's navigate(), so it calls through these globals).
      (window as any).__landerNavigate = navigate;
      (window as any).__landerResolveUrl = resolveStepUrl;

      function _isMobileDevice(): boolean {
        return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
          navigator.userAgent || navigator.vendor || (window as any).opera || ''
        );
      }

      /** Returns the corrected same-origin pathname, or null if already correct. */
      function resolveStepUrl(pathname: string): string | null {
        const configs: Record<string, { variants: string[]; hasMobileRoute: boolean }> =
          (window as any).__landerCampaignConfigs ?? {};

        const parts = pathname.replace(/\/$/, '').split('/').filter(Boolean);
        if (parts.length < 2) return null;

        const campaignId = parts[0];
        const config = configs[campaignId];
        if (!config) return null;

        const { variants, hasMobileRoute } = config;
        const stepSlug = parts[parts.length - 1];
        const slugNoMobile = stepSlug.endsWith('.mobile') ? stepSlug.slice(0, -7) : stepSlug;

        let currentVariant: string | null = null;
        let baseStepSlug = slugNoMobile;
        for (const v of variants) {
          if (slugNoMobile.endsWith('.' + v)) {
            currentVariant = v;
            baseStepSlug = slugNoMobile.slice(0, -(v.length + 1));
            break;
          }
        }

        let targetVariant = currentVariant;
        if (variants.length > 0) {
          const stored = localStorage.getItem(`lander-variant-${campaignId}`);
          if (stored && variants.includes(stored)) {
            targetVariant = stored;
          } else if (!currentVariant) {
            targetVariant = variants[Math.floor(Math.random() * variants.length)];
            localStorage.setItem(`lander-variant-${campaignId}`, targetVariant);
          }
        }

        const targetMobile = hasMobileRoute && _isMobileDevice();

        let targetSlug = baseStepSlug;
        if (targetVariant) targetSlug += '.' + targetVariant;
        if (targetMobile)  targetSlug += '.mobile';

        if (targetSlug === stepSlug) return null;
        parts[parts.length - 1] = targetSlug;
        return '/' + parts.join('/');
      }

      /** Patch every same-origin <a> on the page with the correct suffix. */
      function rewriteLinks(): void {
        if (location.search.includes('no-redirect')) return;
        document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach(a => {
          try {
            const url = new URL(a.href);
            if (url.origin !== location.origin) return;
            const corrected = resolveStepUrl(url.pathname);
            if (corrected) a.href = corrected + url.search + url.hash;
          } catch { /* non-parseable href */ }
        });
      }

      // --- Click interceptor (capture phase, fires before Astro's bubble handler) ---
      // Handles dynamically-added links that rewriteLinks() may have missed.
      // stopImmediatePropagation() prevents Astro's router from also handling
      // the same click and causing a double navigation.
      document.addEventListener('click', (e: MouseEvent) => {
        if (location.search.includes('no-redirect')) return;
        const a = (e.target as Element).closest('a');
        if (!a) return;
        let url: URL;
        try { url = new URL((a as HTMLAnchorElement).href); } catch { return; }
        if (url.origin !== location.origin) return;
        const corrected = resolveStepUrl(url.pathname);
        if (!corrected) return;
        // Steal the event: we will navigate to the correct URL ourselves.
        e.preventDefault();
        e.stopImmediatePropagation();
        navigate(corrected + url.search + url.hash);
      }, { capture: true });

      // --- After every View Transition swap ---
      // Only reveal the body when the current URL is already correct.
      // If a redirect is still needed, keep the body hidden — astro:page-load
      // will call navigate() and the *next* after-swap will reveal the body on
      // the correct page.  This prevents any flash of the un-suffixed page.
      document.addEventListener('astro:after-swap', () => {
        if (!resolveStepUrl(location.pathname)) {
          document.body.style.visibility = 'visible';
        }
      });

      // --- astro:page-load: runs after initial load AND after every transition ---
      // On initial load: redirect via navigate() if URL is wrong (smooth VT, no
      // hard reload), then show body and rewrite links once correct.
      // On post-transition load: URL is already correct; just rewrite links.
      document.addEventListener('astro:page-load', () => {
        if (location.search.includes('no-redirect')) {
          document.body.style.visibility = 'visible';
          return;
        }
        const corrected = resolveStepUrl(location.pathname);
        if (corrected) {
          // Body stays hidden — astro:after-swap will reveal it on the correct page.
          navigate(corrected + location.search);
          return;
        }
        document.body.style.visibility = 'visible';
        rewriteLinks();
      });
    </script>

    <!--
      Unified client-side routing script.
      Handles two concerns in one pass to avoid double-redirects:
        1. A/B variant assignment — randomly assigns the user to a variant on first visit
           and persists the choice in localStorage for the campaign lifetime.
        2. Mobile device detection — redirects between the base and `.mobile` URL variants.

      URL scheme: /{campaign}/{stepId}[.{variant}][.mobile]
      Examples:
        /campaign_alpha/main
        /campaign_alpha/main.mobile
        /campaign_alpha/main.variant_a
        /campaign_alpha/main.variant_a.mobile
    -->
    <!--
      Inline script: registers this page's campaign config synchronously so it is
      available to the module script above as soon as it runs.  Also shows the
      body immediately when the URL is already correct, avoiding any visible delay.
      When the URL needs fixing the body stays hidden — the module script handles
      the redirect via navigate() so there is never a hard location.replace().
    -->
    <script is:inline define:vars={{ variants, hasMobileRoute, campaignId }}>
      (function () {
        // Register config for the SPA helpers in the module script.
        window.__landerCampaignConfigs = window.__landerCampaignConfigs || {};
        window.__landerCampaignConfigs[campaignId] = { variants: variants, hasMobileRoute: hasMobileRoute };

        if (window.location.search.includes('no-redirect')) {
          document.body.style.visibility = 'visible';
          return;
        }

        var pathname = window.location.pathname.replace(/\/$/, '');
        var parts = pathname.split('/');
        var stepSlug = parts[parts.length - 1];

        var slugNoMobile = stepSlug.endsWith('.mobile') ? stepSlug.slice(0, stepSlug.length - 7) : stepSlug;

        var currentVariant = null;
        var baseStepSlug = slugNoMobile;
        for (var i = 0; i < variants.length; i++) {
          var v = variants[i];
          if (slugNoMobile.endsWith('.' + v)) {
            currentVariant = v;
            baseStepSlug = slugNoMobile.slice(0, slugNoMobile.length - v.length - 1);
            break;
          }
        }

        var targetVariant = currentVariant;
        if (variants.length > 0) {
          var stored = localStorage.getItem('lander-variant-' + campaignId);
          if (stored !== null && variants.indexOf(stored) !== -1) {
            targetVariant = stored;
          } else if (!currentVariant) {
            targetVariant = variants[Math.floor(Math.random() * variants.length)];
            localStorage.setItem('lander-variant-' + campaignId, targetVariant);
          }
        }

        function isMobileDevice() {
          return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
            navigator.userAgent || navigator.vendor || window.opera
          );
        }
        var targetMobile = hasMobileRoute && isMobileDevice();

        var targetSlug = baseStepSlug;
        if (targetVariant) targetSlug += '.' + targetVariant;
        if (targetMobile)  targetSlug += '.mobile';

        // If the URL is already correct, reveal the body right now — before the
        // (deferred) module script even loads, for the fastest possible display.
        // If wrong, keep it hidden; the module script's astro:page-load will call
        // navigate() for a smooth View Transition to the correct URL.
        if (targetSlug === stepSlug) {
          document.body.style.visibility = 'visible';
        }
      })();
    </script>

    <script is:inline define:vars={{ initialState }}>
      document.addEventListener('click', function (e) {
        var modal = e.target.closest('.lander-modal');
        if (modal && e.target === modal) {
          if (modal.dataset.closeOnBackdrop === 'true') {
            modal.classList.add('modal-hidden');
          }
        }
      });
    </script>
  </body>
</html>
