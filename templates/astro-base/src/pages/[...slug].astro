---
import { ConfigParser, resolveCascadingConfig } from 'lander-engine/resolver';
import { hydrateState } from 'lander-engine/core';
import '../registry-manifest'; 
import Registry from '../Registry.astro';
import ModalsContainer from '../ModalsContainer.astro';

export async function getStaticPaths() {
  const nodeEnvJsonDir = process.env.LANDER_JSON_CONFIGS_DIR;
  const viteEnvJsonDir = import.meta.env.LANDER_JSON_CONFIGS_DIR;
  const jsonConfigsDir = nodeEnvJsonDir || viteEnvJsonDir || '';

  if (!jsonConfigsDir) {
    console.error('❌ LANDER_JSON_CONFIGS_DIR is not defined');
    return [];
  }

  try {
    const parser = new ConfigParser(jsonConfigsDir);
    const campaigns = await parser.getCampaigns();
    
    if (campaigns.length === 0) {
      console.warn('⚠ No campaigns found in:', jsonConfigsDir);
      return [];
    }

    const paths: any[] = [];

    for (const campaignId of campaigns) {
      try {
        // Load base campaign (without device/variant overrides)
        // In production, you might want to generate separate builds for different variants/devices
        const { config, metadata } = await parser.loadCampaignWithOverrides(campaignId);
        
        // Generate routes for each normal (non-popup) step
        for (const [stepId, stepConfig] of Object.entries(config.steps)) {
          const stepType = config.flow.steps[stepId]?.type;
          
          // Only create routes for normal steps, skip popups
          if (stepType !== 'popup') {
            paths.push({
              params: { slug: `${campaignId}/${stepId}` },
              props: { 
                campaignId, 
                stepId, 
                config,
                step: stepConfig,
                flow: config.flow,
                allSteps: config.steps,
                modalConfigs: config.flow.modals || {},
                layout: config.layout || {},
                metadata,
              }
            });
          }
        }
      } catch (error) {
        console.error(`❌ Failed to load campaign '${campaignId}':`, error instanceof Error ? error.message : String(error));
      }
    }

    if (paths.length === 0) {
      console.warn('⚠ No valid routes generated from campaigns');
    }

    return paths;
  } catch (error) {
    console.error('❌ Error generating static paths:', error instanceof Error ? error.message : String(error));
    return [];
  }
}

const { config, step, campaignId, stepId, flow, allSteps, modalConfigs, layout, metadata } = Astro.props;

// Prepare initial state with override information
const initialState = {
  ...config.state,
  ...step.state,
  campaignId,
  stepId,
  // Include which overrides were applied for debugging/analytics
  appliedOverrides: metadata?.appliedOverrides || {},
};

// Collect available popups for this step (popups that can be triggered from this step)
const availablePopups: Record<string, any> = {};
for (const [popupId, popupStepConfig] of Object.entries(allSteps)) {
  if (flow.steps[popupId]?.type === 'popup') {
    availablePopups[popupId] = popupStepConfig;
  }
}

// Map theme colors to CSS variables
const themeVars = Object.entries(config.theme.colors || {}).reduce((acc, [key, val]) => {
  acc[`--color-${key.replace(/([A-Z])/g, '-$1').toLowerCase()}`] = val;
  return acc;
}, {} as Record<string, string>);

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={step.seo?.description || config.seo.description || ''} />
    <title>{step.seo?.title || config.seo.title || campaignId}</title>
    <!-- Include variant/device info for analytics -->
    {metadata?.variant && <meta name="lander:variant" content={metadata.variant} />}
    {metadata?.device && <meta name="lander:device" content={metadata.device} />}
  </head>
  <body style={themeVars}>
    {layout?.header && (
      <header id="lander-header">
        <Registry component={layout.header.component} props={layout.header.props} />
      </header>
    )}
    
    <main id="lander-engine-root">
      {step.sections && step.sections.map((section: any) => (
        <Registry component={section.component} props={section.props} />
      ))}
    </main>

    {layout?.footer && (
      <footer id="lander-footer">
        <Registry component={layout.footer.component} props={layout.footer.props} />
      </footer>
    )}

    <ModalsContainer popups={availablePopups} modalConfigs={modalConfigs} />

    <script is:inline define:vars={{ initialState }}>
      // Initialize state before hydration
      // This script runs before any client-side code to seed the store
      (function() {
        try {
          // State is available globally during hydration via the registry-manifest
          window.__LANDER_INITIAL_STATE__ = initialState;
          console.debug('[lander-engine] Initial state seeded:', initialState);
        } catch (e) {
          console.error('[lander-engine] Failed to initialize state:', e);
        }
      })();
    </script>
  </body>
</html>
